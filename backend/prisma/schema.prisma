generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String    // bcrypt hashed
  fullName      String
  phone         String?
  kycStatus     String    @default("pending") // pending, verified, rejected
  kycData       Json?
  walletAddress String?   @unique
  role          String    @default("investor") // investor, admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  investments   Investment[]
  transactions  Transaction[]
}

model Property {
  id                  String    @id @default(uuid())
  name                String
  type                String    // apartment, villa, commercial
  locationEmirate     String    // Dubai, Abu Dhabi, etc
  locationArea        String    // Dubai Marina, Downtown, etc
  address             String?
  
  totalTokens         Int
  availableTokens     Int
  pricePerToken       Decimal   @db.Decimal(10, 2)
  minInvestment       Decimal   @default(500.00) @db.Decimal(10, 2)
  
  sizeSqft            Int?
  bedrooms            Int?
  bathrooms           Int?
  
  purchasePrice       Decimal?  @db.Decimal(15, 2)
  currentValuation    Decimal?  @db.Decimal(15, 2)
  expectedYield       Decimal?  @db.Decimal(5, 2) // percentage
  
  fundedAmount        Decimal   @default(0) @db.Decimal(15, 2)
  fundingGoal         Decimal?  @db.Decimal(15, 2)
  
  status              String    @default("funding") // funding, funded, active, closed
  
  images              Json      // array of image URLs
  amenities           Json?     // array of amenity strings
  description         String?   @db.Text
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  investments         Investment[]
  transactions        Transaction[]
}

model Investment {
  id                String    @id @default(uuid())
  userId            String
  propertyId        String
  
  tokenAmount       Int
  pricePerToken     Decimal   @db.Decimal(10, 2)
  totalPaid         Decimal   @db.Decimal(15, 2)
  
  status            String    @default("completed") // pending, completed, cancelled
  
  purchaseDate      DateTime  @default(now())
  
  user              User      @relation(fields: [userId], references: [id])
  property          Property  @relation(fields: [propertyId], references: [id])
  
  @@unique([userId, propertyId])
}

model Transaction {
  id              String    @id @default(uuid())
  userId          String
  propertyId      String?
  
  type            String    // purchase, sale, dividend, fee
  amount          Decimal   @db.Decimal(15, 2)
  tokenAmount     Int?
  
  status          String    @default("completed") // pending, completed, failed
  description     String?
  
  createdAt       DateTime  @default(now())
  
  user            User      @relation(fields: [userId], references: [id])
  property        Property? @relation(fields: [propertyId], references: [id])
}
